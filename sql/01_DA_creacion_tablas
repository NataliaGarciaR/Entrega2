CREATE TABLE DA_CIUDAD (
  ID_CIUDAD VARCHAR2(10) PRIMARY KEY,
  NOMBRE VARCHAR2(100) NOT NULL UNIQUE
);

CREATE TABLE DA_CLIENTE (
  ID_CLIENTE VARCHAR2(10) PRIMARY KEY,
  IDENTIFICACION VARCHAR2(20) NOT NULL UNIQUE,
  NOMBRE VARCHAR2(100) NOT NULL,
  CORREO VARCHAR2(100),
  TELEFONO NUMBER
);

CREATE TABLE DA_HOTEL (
  ID_HOTEL VARCHAR2(10) PRIMARY KEY,
  NOMBRE VARCHAR2(100) NOT NULL,
  DIRECCION VARCHAR2(150) NOT NULL,
  TELEFONO VARCHAR2(20) NOT NULL,
  ID_CIUDAD VARCHAR2(10),
  FOREIGN KEY (ID_CIUDAD) REFERENCES DA_CIUDAD(ID_CIUDAD)
);

CREATE TABLE DA_TIPO_HABITACION (
  ID_TIPO_HAB VARCHAR2(10) PRIMARY KEY,
  NOMBRE_HAB VARCHAR2(100) NOT NULL,
  DIMENSIONES NUMBER NOT NULL,
  VISTA VARCHAR2(50),
  CAPACIDAD NUMBER NOT NULL
);

CREATE TABLE DA_COMODIDAD (
  ID_COMODIDAD VARCHAR2(10) PRIMARY KEY,
  NOMBRE VARCHAR2(100) NOT NULL
);

CREATE TABLE DA_COMODIDAD_TIPO_HAB (
  ID_TIPO_HAB VARCHAR2(10),
  ID_COMODIDAD VARCHAR2(10),
  PRIMARY KEY (ID_TIPO_HAB, ID_COMODIDAD),
  FOREIGN KEY (ID_TIPO_HAB) REFERENCES DA_TIPO_HABITACION(ID_TIPO_HAB),
  FOREIGN KEY (ID_COMODIDAD) REFERENCES DA_COMODIDAD(ID_COMODIDAD)
);

CREATE TABLE DA_HABITACION (
  ID_HABITACION VARCHAR2(10) PRIMARY KEY,
  ID_TIPO_HAB VARCHAR2(10),
  ID_HOTEL VARCHAR2(10),
  FOREIGN KEY (ID_TIPO_HAB) REFERENCES DA_TIPO_HABITACION(ID_TIPO_HAB),
  FOREIGN KEY (ID_HOTEL) REFERENCES DA_HOTEL(ID_HOTEL)
);

CREATE TABLE DA_SERVICIO (
  ID_SERVICIO VARCHAR2(10) PRIMARY KEY,
  NOMBRE VARCHAR2(100) NOT NULL,
  DESC_CORTA VARCHAR2(100),
  TIPO_COSTO VARCHAR2(50),
  FORMA_COSTO VARCHAR2(50),
  PRECIO_BASE NUMBER
);

CREATE TABLE DA_HOTEL_TIPO_HABITACION (
  ID_HOTEL VARCHAR2(10),
  ID_TIPO_HAB VARCHAR2(10),
  COSTO_ALTA NUMBER,
  COSTO_BAJA NUMBER,
  CANT_DISPONIBLE NUMBER,
  TIPO_CAMA VARCHAR2(50),
  PRIMARY KEY (ID_HOTEL, ID_TIPO_HAB),
  FOREIGN KEY (ID_HOTEL) REFERENCES DA_HOTEL(ID_HOTEL),
  FOREIGN KEY (ID_TIPO_HAB) REFERENCES DA_TIPO_HABITACION(ID_TIPO_HAB)
);

CREATE TABLE DA_RESERVA (
  ID_RESERVA VARCHAR2(10) PRIMARY KEY,
  CODIGO_CONFIRMACION VARCHAR2(50) UNIQUE,
  FECHA_INGRESO DATE,
  FECHA_SALIDA DATE,
  NUM_ADULTOS NUMBER,
  NUM_MENORES NUMBER,
  PRECIO_TOTAL NUMBER,
  ID_CLIENTE VARCHAR2(10),
  ID_HOTEL VARCHAR2(10),
  ID_TIPO_HAB VARCHAR2(10),
  CHECK (FECHA_SALIDA > FECHA_INGRESO),
  FOREIGN KEY (ID_CLIENTE) REFERENCES DA_CLIENTE(ID_CLIENTE),
  FOREIGN KEY (ID_HOTEL) REFERENCES DA_HOTEL(ID_HOTEL),
  FOREIGN KEY (ID_TIPO_HAB) REFERENCES DA_TIPO_HABITACION(ID_TIPO_HAB)
);

CREATE TABLE DA_SERVICIO_RESERVA (
  ID_RESERVA VARCHAR2(10),
  ID_SERVICIO VARCHAR2(10),
  PRIMARY KEY (ID_RESERVA, ID_SERVICIO),
  FOREIGN KEY (ID_RESERVA) REFERENCES DA_RESERVA(ID_RESERVA),
  FOREIGN KEY (ID_SERVICIO) REFERENCES DA_SERVICIO(ID_SERVICIO)
);

CREATE TABLE DA_SERVICIO_TIPO_HABITACION (
  ID_TIPO_HAB VARCHAR2(10),
  ID_SERVICIO VARCHAR2(10),
  SOBRECOSTO NUMBER,
  PRIMARY KEY (ID_TIPO_HAB, ID_SERVICIO),
  FOREIGN KEY (ID_TIPO_HAB) REFERENCES DA_TIPO_HABITACION(ID_TIPO_HAB),
  FOREIGN KEY (ID_SERVICIO) REFERENCES DA_SERVICIO(ID_SERVICIO)
);
